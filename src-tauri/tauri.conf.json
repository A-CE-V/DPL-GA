{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deploy Launcher",
  "version": "1.0.0",
  "identifier": "com.deploy.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Deploy Launcher",
        "width": 900,
        "height": 600,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxNzlCOURDQTg5ODVCREMKUldUY1c1aW8zTGw1Z2NqWHdBbEJ3Zk41VFJKeHVKM0c1YmVZUmFHeHdSZzJsZTFDeno4bTdFZ3oK",
      "endpoints": [
        "https://REPLACE_WITH_YOUR_UPDATE_SERVER/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
